DATABASE_URL="file:./dev.db"
PORT=5000
JWT_SECRET="replace-me"
FRONTEND_URL="http://localhost:5173"

# Google Drive (optional)
GOOGLE_DRIVE_MODE="oauth"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:5000/api/storage/google/callback"

# Mail (optional). If SMTP_HOST is not set, emails are logged to the server console.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@nemsuee.local"

# Azure App Service also works with these aliases (optional):
# APPSETTING_SMTP_HOST / APPSETTING_SMTP_PORT / APPSETTING_SMTP_USER / APPSETTING_SMTP_PASS / APPSETTING_SMTP_FROM / APPSETTING_SMTP_SECURE
# AZURE_SMTP_HOST / AZURE_SMTP_PORT / AZURE_SMTP_USER / AZURE_SMTP_PASS / AZURE_SMTP_FROM / AZURE_SMTP_SECURE
